# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev — zero setup required)
DATABASE_URL=sqlite+aiosqlite:///./personal_clone.db

# PostgreSQL (swap this in when you move to Supabase/prod):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/personal_clone

# ── OpenAI (needed once we wire in the AI call) ───────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
CLONE_API_KEY=replace-with-a-long-random-secret
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Personal Clone
DEBUG=false
