# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_clone
# Local SQLite fallback (optional)
# DATABASE_URL=sqlite+aiosqlite:///./personal_clone.db

# AI Providers — configure at least one
OPENAI_API_KEY=sk-your-key-here           # platform.openai.com (paid)
ANTHROPIC_API_KEY=your-anthropic-key-here  # console.anthropic.com (paid)
GROQ_API_KEY=gsk_your-key-here            # console.groq.com (FREE tier)
GEMINI_API_KEY=                           # aistudio.google.com (FREE tier)
DEFAULT_AI_PROVIDER=openai                # openai | anthropic | groq | gemini
EMAIL_AI_PROVIDER=                        # Override for email AI; blank = use DEFAULT_AI_PROVIDER
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
AGENT_MODEL_GROQ=llama-3.3-70b-versatile
AGENT_MODEL_GEMINI=gemini-2.0-flash

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=                          # Gmail callback (e.g. http://localhost:8002/api/v1/email/callback)
GOOGLE_CALENDAR_REDIRECT_URI=                 # Calendar callback (e.g. http://localhost:8002/api/v1/integrations/google-calendar/oauth/callback)

# WhatsApp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Internal
CLONE_API_KEY=replace-with-a-long-random-secret
CORS_ALLOWED_ORIGINS=                         # Comma-separated: http://localhost:8002,https://app.nidin.ai
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_BACKEND=auto
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=pc:ratelimit
IDEMPOTENCY_BACKEND=auto
IDEMPOTENCY_REDIS_URL=
IDEMPOTENCY_REDIS_PREFIX=pc:idempotency
IDEMPOTENCY_TTL_SECONDS=1800
IDEMPOTENCY_MAX_ITEMS=5000

# App
APP_NAME=Personal Clone
APP_MODE=NIDIN_AI                         # NIDIN_AI | EMPIREO_AI
DEBUG=true
ENFORCE_STARTUP_VALIDATION=false
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false
COOKIE_SECURE=false                       # Set true in production (requires HTTPS)
SECRET_KEY=your_32_plus_char_secret_here
TOKEN_ENCRYPTION_KEY=                     # Separate from SECRET_KEY; min 32 chars
OAUTH_STATE_KEY=                          # Separate from SECRET_KEY for OAuth state HMAC
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480           # 8 hours for dev; use 30 in production
ADMIN_EMAIL=demo@ai.com
ADMIN_PASSWORD=                           # Min 8 chars; weak defaults rejected at startup
ADMIN_NAME=Your Name

# Privacy
PRIVACY_REDACTION_ENABLED=true
PRIVACY_MASK_PII=true
PRIVACY_RESPONSE_SANITIZATION_ENABLED=true
PRIVACY_AUDIT_MAX_VALUE_CHARS=200
CLONE_AUTO_LEARN_FROM_CHAT=true

# Database connection pool (PostgreSQL only; ignored for SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Email compose rate limiting
COMPOSE_MAX_PER_HOUR=20
COMPOSE_WINDOW_SECONDS=3600

# Background sync
RUN_SCHEDULER=false                           # Set true for single-worker; false if running scheduler as separate process
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=30
SYNC_THROTTLE_MINUTES=15

# Logging
LOG_FORMAT=text                               # text | json
LOG_LEVEL=INFO

# CEO control + compliance
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PEM=
GITHUB_ORG=
CRITICAL_GITHUB_REPOS=
GITHUB_TECH_LEADS=sharonempire
GITHUB_DEVELOPERS=akshayempireoe,sanjayempire
COMPLIANCE_OWNER_EMAILS=nidin@empireoe.com,admin@empireoe.com
COMPLIANCE_TECH_LEAD_EMAIL=sharon@empireoe.com
COMPLIANCE_OPS_MANAGER_EMAIL=mano@empireoe.com
COMPLIANCE_DEV_EMAILS=dev1@empireoe.com,dev2@empireoe.com,dev3@empireoe.com,dev4@empireoe.com
CLICKUP_CRITICAL_FOLDER_NAME=🔴 Critical Systems
CLICKUP_CEO_PRIORITY_TAG=CEO-PRIORITY
DIGITALOCEAN_BASE_URL=https://api.digitalocean.com/v2
