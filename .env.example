# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_clone
# Local SQLite fallback (optional)
# DATABASE_URL=sqlite+aiosqlite:///./personal_clone.db

# AI Providers — configure at least one
OPENAI_API_KEY=sk-your-key-here           # platform.openai.com (paid)
ANTHROPIC_API_KEY=your-anthropic-key-here  # console.anthropic.com (paid)
GROQ_API_KEY=gsk_your-key-here            # console.groq.com (FREE tier)
DEFAULT_AI_PROVIDER=openai                # openai | anthropic | groq
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
AGENT_MODEL_GROQ=llama-3.3-70b-versatile

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Internal
CLONE_API_KEY=replace-with-a-long-random-secret
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
IDEMPOTENCY_BACKEND=auto
IDEMPOTENCY_REDIS_URL=
IDEMPOTENCY_REDIS_PREFIX=pc:idempotency
IDEMPOTENCY_TTL_SECONDS=1800
IDEMPOTENCY_MAX_ITEMS=5000

# App
APP_NAME=Personal Clone
APP_MODE=NIDIN_AI
DEBUG=false
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false
COOKIE_SECURE=false   # Set true in production (requires HTTPS)
SECRET_KEY=your_32_plus_char_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
