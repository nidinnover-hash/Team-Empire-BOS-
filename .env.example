# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_clone
# Local SQLite fallback (optional)
# DATABASE_URL=sqlite+aiosqlite:///./personal_clone.db

# OpenAI
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
DEFAULT_AI_PROVIDER=openai
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Internal
CLONE_API_KEY=replace-with-a-long-random-secret
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

# App
APP_NAME=Personal Clone
DEBUG=false
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false
SECRET_KEY=change-me-to-a-long-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
