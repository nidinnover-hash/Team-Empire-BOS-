# Production-oriented environment template.
# Copy to your deployment secret manager or host-specific env file.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_clone

# AI Providers - configure at least one
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEFAULT_AI_PROVIDER=openai
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
AGENT_MODEL_GROQ=llama-3.3-70b-versatile

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Internal
CLONE_API_KEY=replace-with-a-long-random-secret
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
IDEMPOTENCY_BACKEND=redis
IDEMPOTENCY_REDIS_URL=redis://localhost:6379/0
IDEMPOTENCY_REDIS_PREFIX=pc:idempotency
IDEMPOTENCY_TTL_SECONDS=1800
IDEMPOTENCY_MAX_ITEMS=5000

# App hardening
APP_NAME=Personal Clone
APP_MODE=NIDIN_AI
DEBUG=false
ENFORCE_STARTUP_VALIDATION=true
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false
COOKIE_SECURE=true
SECRET_KEY=replace-with-64-char-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
