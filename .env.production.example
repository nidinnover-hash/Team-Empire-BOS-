# Production-oriented environment template.
# Copy to your deployment secret manager or host-specific env file.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_clone

# AI Providers - configure at least one
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEFAULT_AI_PROVIDER=openai
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
AGENT_MODEL_GROQ=llama-3.3-70b-versatile

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# WhatsApp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Internal
CLONE_API_KEY=replace-with-a-long-random-secret
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REDIS_PREFIX=pc:ratelimit
IDEMPOTENCY_BACKEND=redis
IDEMPOTENCY_REDIS_URL=redis://localhost:6379/0
IDEMPOTENCY_REDIS_PREFIX=pc:idempotency
IDEMPOTENCY_TTL_SECONDS=1800
IDEMPOTENCY_MAX_ITEMS=5000
USE_FORWARDED_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32

# App hardening
APP_NAME=Personal Clone
APP_MODE=NIDIN_AI
DEBUG=false
ENFORCE_STARTUP_VALIDATION=true
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false
COOKIE_SECURE=true
SECRET_KEY=replace-with-64-char-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-different-64-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
WEB_API_TOKEN_EXPIRE_MINUTES=10
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_NAME=Your Name Here

# Privacy
PRIVACY_REDACTION_ENABLED=true
PRIVACY_MASK_PII=true
PRIVACY_RESPONSE_SANITIZATION_ENABLED=true
PRIVACY_AUDIT_MAX_VALUE_CHARS=200
CLONE_AUTO_LEARN_FROM_CHAT=true

# Logging
LOG_FORMAT=json

# Background sync
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=30
SYNC_THROTTLE_MINUTES=15
MEMORY_CONTEXT_CACHE_TTL_SECONDS=300
MEMORY_CONTEXT_CACHE_MAX_ORGS=200
