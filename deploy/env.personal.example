# ═══════════════════════════════════════════════════════════════════════
# Personal Clone — clone.nidin.ai (Nidin's personal AI assistant)
# Droplet: Ubuntu 22.04, DO Managed PostgreSQL
# ═══════════════════════════════════════════════════════════════════════

# Database — DO Managed PostgreSQL (get connection string from DO dashboard)
DATABASE_URL=postgresql+asyncpg://doadmin:PASSWORD@db-host-personal-xxxx.ondigitalocean.com:25060/personal_clone?sslmode=require

# AI Providers
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk_your-groq-key
GEMINI_API_KEY=your-gemini-key
DEFAULT_AI_PROVIDER=openai
EMAIL_AI_PROVIDER=gemini
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_GROQ=llama-3.3-70b-versatile
AGENT_MODEL_GEMINI=gemini-2.0-flash

# Google OAuth — register clone.nidin.ai in Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=https://clone.nidin.ai/api/v1/email/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://clone.nidin.ai/api/v1/integrations/google-calendar/oauth/callback

# App Identity
APP_NAME=Nidin Nover
APP_MODE=NIDIN_AI
APP_VERSION=1.0.0
DEBUG=false
ENFORCE_STARTUP_VALIDATION=true
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false

# Security — generate these with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_A_64_CHAR_HEX_SECRET
TOKEN_ENCRYPTION_KEY=GENERATE_A_DIFFERENT_64_CHAR_HEX_SECRET
COOKIE_SECURE=true
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
WEB_API_TOKEN_EXPIRE_MINUTES=10

# Admin account
ADMIN_EMAIL=nidinnover@gmail.com
ADMIN_PASSWORD=STRONG_PASSWORD_HERE
ADMIN_NAME=Nidin Nover

# Rate limiting — use Redis in production for multi-worker safety
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_REDIS_PREFIX=nidin:ratelimit

# Idempotency
IDEMPOTENCY_BACKEND=redis
IDEMPOTENCY_REDIS_URL=redis://127.0.0.1:6379/0
IDEMPOTENCY_REDIS_PREFIX=nidin:idempotency

# CORS — only allow the production domain
CORS_ALLOWED_ORIGINS=https://clone.nidin.ai
USE_FORWARDED_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Privacy
PRIVACY_REDACTION_ENABLED=true
PRIVACY_MASK_PII=true
PRIVACY_RESPONSE_SANITIZATION_ENABLED=true
PRIVACY_POLICY_PROFILE=strict

# Sync
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=30
SYNC_THROTTLE_MINUTES=15
MEMORY_CONTEXT_CACHE_TTL_SECONDS=300
MEMORY_CONTEXT_CACHE_MAX_ORGS=200
CEO_SUMMARY_TIMEZONE=Asia/Kolkata

# Feature flags
FEATURE_AI_COMMANDS=true
FEATURE_EMAIL_SYNC=true
FEATURE_TALK_MODE=true
FEATURE_OPS_INTEL=true
FEATURE_DAILY_RUN=true
