# ═══════════════════════════════════════════════════════════════════════
# Empire Overseas Education — ai.empireoe.com (Company AI assistant)
# Droplet: Ubuntu 22.04, DO Managed PostgreSQL (SEPARATE from personal)
# ═══════════════════════════════════════════════════════════════════════

# Database — DO Managed PostgreSQL (separate database cluster from personal)
DATABASE_URL=postgresql+asyncpg://doadmin:PASSWORD@db-host-empireoe-xxxx.ondigitalocean.com:25060/empireoe_clone?sslmode=require

# AI Providers
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk_your-groq-key
GEMINI_API_KEY=your-gemini-key
DEFAULT_AI_PROVIDER=gemini
EMAIL_AI_PROVIDER=gemini
AGENT_MODEL_OPENAI=gpt-4o-mini
AGENT_MODEL_GROQ=llama-3.3-70b-versatile
AGENT_MODEL_GEMINI=gemini-2.0-flash

# Google OAuth — register ai.empireoe.com in Google Cloud Console
GOOGLE_CLIENT_ID=your-empireoe-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-empireoe-secret
GOOGLE_REDIRECT_URI=https://ai.empireoe.com/api/v1/email/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://ai.empireoe.com/api/v1/integrations/google-calendar/oauth/callback

# App Identity
APP_NAME=Empire OE AI
APP_MODE=EMPIREO_AI
APP_VERSION=1.0.0
DEBUG=false
ENFORCE_STARTUP_VALIDATION=true
AUTO_CREATE_SCHEMA=false
AUTO_SEED_DEFAULTS=false

# Security — generate these with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_A_64_CHAR_HEX_SECRET
TOKEN_ENCRYPTION_KEY=GENERATE_A_DIFFERENT_64_CHAR_HEX_SECRET
OAUTH_STATE_KEY=GENERATE_A_THIRD_64_CHAR_HEX_SECRET
COOKIE_SECURE=true
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
WEB_API_TOKEN_EXPIRE_MINUTES=10
SECURITY_PREMIUM_MODE=true
ACCOUNT_MFA_REQUIRED=true
LEGAL_DPA_REQUIRED=true
LEGAL_TERMS_VERSION=2026-02-24
MARKETING_EXPORT_PII_ALLOWED=false

# Admin account
ADMIN_EMAIL=nidin@empireoe.com
ADMIN_PASSWORD=STRONG_PASSWORD_HERE
ADMIN_NAME=Nidin Nover

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_REDIS_PREFIX=empireoe:ratelimit

# Idempotency
IDEMPOTENCY_BACKEND=redis
IDEMPOTENCY_REDIS_URL=redis://127.0.0.1:6379/0
IDEMPOTENCY_REDIS_PREFIX=empireoe:idempotency

# CORS
CORS_ALLOWED_ORIGINS=https://ai.empireoe.com
USE_FORWARDED_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Ops Intelligence — filter work email domains
WORK_EMAIL_DOMAINS=empireoe.com

# Privacy
PRIVACY_REDACTION_ENABLED=true
PRIVACY_MASK_PII=true
PRIVACY_RESPONSE_SANITIZATION_ENABLED=true
PRIVACY_POLICY_PROFILE=strict

# Purpose barriers
PURPOSE_STRICT_BARRIERS=true
PURPOSE_PERSONAL_EMAILS=nidin@empireoe.com
PURPOSE_ENTERTAINMENT_EMAILS=

# Logging — use JSON for structured log aggregation in production
LOG_FORMAT=json
LOG_LEVEL=INFO

# Sync
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=30
SYNC_THROTTLE_MINUTES=15
MEMORY_CONTEXT_CACHE_TTL_SECONDS=300
MEMORY_CONTEXT_CACHE_MAX_ORGS=200
CEO_SUMMARY_TIMEZONE=Asia/Kolkata

# Gunicorn — port 8001 to avoid collision with personal instance on 8000
GUNICORN_BIND=127.0.0.1:8001

# Feature flags
FEATURE_AI_COMMANDS=true
FEATURE_EMAIL_SYNC=true
FEATURE_TALK_MODE=true
FEATURE_OPS_INTEL=true
FEATURE_DAILY_RUN=true
